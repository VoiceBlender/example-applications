# Contact Centre — example environment variables.
# Copy to .env and adjust as needed.

# VoiceBlender REST + VSI base URL. The app derives the VSI WebSocket URL
# from this (http → ws, https → wss; appends /vsi).
VOICEBLENDER_URL=http://localhost:8080/v1

# Address this app's HTTP server listens on. Serves the operator panel at /,
# the call-snapshot API at /api/calls, a WebSocket stream at /api/calls/stream,
# and the hold-music MP3 at /moh/.
LISTEN_ADDR=:8090

# URL VoiceBlender will fetch the hold-music MP3 from. Default points at this
# app's own /moh/ file server, so just drop new_music.mp3 into ./assets/.
HOLD_MUSIC_URL=http://localhost:8090/moh/new_music.mp3

# How often to repeat the queue-position announcement.
ANNOUNCEMENT_INTERVAL=20s

# Codec preference order for answering inbound SIP calls — comma
# separated. Applied to both the 183 early-media SDP (ringback) and the
# 200 OK answer SDP. The app picks the FIRST codec in this list that the
# caller actually offered (per the leg.ringing offered_codecs), so a
# codec that isn't offered is simply skipped. If none match — or this is
# unset — VoiceBlender uses its own default preference order. Valid
# names: PCMU, PCMA, G722, opus.
# ANSWER_CODECS=opus,PCMA,PCMU

# TTS settings.
TTS_VOICE=Rachel
TTS_PROVIDER=elevenlabs
# TTS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Auth -------------------------------------------------------------------
# Static passwords gating the supervisor and agent panels. Cookie-session
# based: a /login page takes a username + password, the server issues a
# session cookie, and the panel + its WebSocket are gated until sign-out.
#
# Only the password is validated. The username field is free-form —
# anyone can sign in with any username as long as they know the
# configured password. It's logged on each successful sign-in for a
# light audit trail.
#
# Leave a password empty (or unset) to disable auth for that side —
# useful for local dev. Each side is independently configurable, so
# you can lock down the supervisor and keep agent open, or vice versa.
# SUPERVISOR_PASSWORD=letmein
# AGENT_PASSWORD=letmein

# --- Service KPIs -----------------------------------------------------------
# SLA threshold for the Service Level KPI: share of calls answered in <= this.
# 20s is the classic 80/20 industry default. Any time.ParseDuration value works.
SLA_THRESHOLD=20s

# Rolling window for KPI averages (Service Level, ASA, AHT, Abandon Rate) and
# counters on the supervisor's Metrics board. Longest Wait is always "now".
METRICS_WINDOW=30m

# --- STT (live transcription) -----------------------------------------------
# Started automatically on every call once an agent answers. Finals are
# streamed to the supervisor's panel and persisted in the call log.
# Language is ISO-639-1 (e.g. "en", "es"). Provider is "elevenlabs" or
# "deepgram". API key is optional if the VoiceBlender server is configured
# with one for the chosen provider.
STT_LANGUAGE=en
STT_PROVIDER=elevenlabs
# STT_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Call log ---------------------------------------------------------------
# Where to persist the historical call log shown on the supervisor panel.
#   memory  in-process ring buffer (default, lost on restart)
#   redis   any Redis-compatible server (Redis, Valkey, KeyDB, Dragonfly, …)
CALL_LOG_BACKEND=memory

# Cap on the number of entries the log retains; oldest entries are evicted
# when full. Applies to both backends.
CALL_LOG_MAX=200

# Required when CALL_LOG_BACKEND=redis. Standard Redis URL.
# CALL_LOG_REDIS_URL=redis://localhost:6379/0
# CALL_LOG_REDIS_KEY=contactcentre:call_log
